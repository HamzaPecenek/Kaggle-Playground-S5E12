train[col].value_counts().plot(kind='bar', ax=axes[idx], color='coral', alpha=0.7)\n    axes[idx].set_title(f'{col}', fontsize=11, fontweight='bold')\n    axes[idx].set_xlabel('')\n    axes[idx].tick_params(axis='x', rotation=45)\n\nplt.tight_layout()\nplt.show()\n\n# %% Correlation with Target\nprint(\"\\n\" + \"=\"*80)\nprint(\"CORRELATION WITH TARGET\")\nprint(\"=\"*80)\n\n# Numerical correlations\ncorrelations = train[numerical_cols + ['diagnosed_diabetes']].corr()['diagnosed_diabetes'].sort_values(ascending=False)\nprint(\"\\nNumerical Features Correlation:\")\nprint(correlations)\n\n# Visualize top correlations\nfig, ax = plt.subplots(figsize=(10, 8))\ncorrelations[1:].sort_values().plot(kind='barh', ax=ax, color='teal')\nax.set_title('Feature Correlation with Diagnosed Diabetes', fontsize=14, fontweight='bold')\nax.set_xlabel('Correlation Coefficient')\nplt.tight_layout()\nplt.show()\n\n# %% [markdown]\n# # 🛠️ Feature Engineering\n\n# %% Feature Engineering Function\ndef feature_engineering(df):\n    \"\"\"Create new features from existing ones\"\"\"\n    df = df.copy()\n    \n    # BMI categories\n    df['bmi_category'] = pd.cut(df['bmi'], bins=[0, 18.5, 25, 30, 100], \n                                labels=['underweight', 'normal', 'overweight', 'obese'])\n    \n    # Age groups\n    df['age_group'] = pd.cut(df['age'], bins=[0, 30, 40, 50, 60, 100], \n                             labels=['young', 'adult', 'middle', 'senior', 'elderly'])\n    \n    # Blood pressure categories\n    df['bp_category'] = 'normal'\n    df.loc[(df['systolic_bp'] >= 130) | (df['diastolic_bp'] >= 80), 'bp_category'] = 'high'\n    df.loc[(df['systolic_bp'] < 90) | (df['diastolic_bp'] < 60), 'bp_category'] = 'low'\n    \n    # Cholesterol ratio\n    df['cholesterol_ratio'] = df['ldl_cholesterol'] / (df['hdl_cholesterol'] + 1e-5)\n    df['hdl_ldl_sum'] = df['hdl_cholesterol'] + df['ldl_cholesterol']\n    \n    # Metabolic score (combination of key metabolic indicators)\n    df['metabolic_score'] = (\n        (df['bmi'] / df['bmi'].max()) * 0.3 +\n        (df['systolic_bp'] / df['systolic_bp'].max()) * 0.2 +\n        (df['cholesterol_total'] / df['cholesterol_total'].max()) * 0.2 +\n        (df['triglycerides'] / df['triglycerides'].max()) * 0.15 +\n        (df['waist_to_hip_ratio'] / df['waist_to_hip_ratio'].max()) * 0.15\n    )\n    \n    # Lifestyle score\n    df['lifestyle_score'] = (\n        (df['physical_activity_minutes_per_week'] / df['physical_activity_minutes_per_week'].max()) * 0.4 +\n        (df['diet_score'] / df['diet_score'].max()) * 0.3 +\n        (df['sleep_hours_per_day'] / 10) * 0.2 -\n        (df['screen_time_hours_per_day'] / 24) * 0.1\n    )\n    \n    # Risk factors count\n    df['risk_factors'] = (\n        (df['family_history_diabetes'] == 1).astype(int) +\n        (df['hypertension_history'] == 1).astype(int) +\n        (df['cardiovascular_history'] == 1).astype(int) +\n        (df['bmi'] > 30).astype(int) +\n        (df['smoking_status'] == 'Current').astype(int)\n    )\n    \n    # Interaction features\n    df['age_bmi'] = df['age'] * df['bmi']\n    df['age_bp'] = df['age'] * df['systolic_bp']\n    df['bmi_bp'] = df['bmi'] * df['systolic_bp']\n    \n    # Health indicators\n    df['pulse_pressure'] = df['systolic_bp'] - df['diastolic_bp']\n    df['map'] = df['diastolic_bp'] + (df['pulse_pressure'] / 3)  # Mean Arterial Pressure\n    \n    return df\n\n# Apply feature engineering\nprint(\"\\nApplying feature engineering...\")\ntrain_fe = feature_engineering(train)\ntest_fe = feature_engineering(test)\n\nprint(f\"New train shape: {train_fe.shape}\")\nprint(f\"New test shape: {test_fe.shape}\")\n\n# %% Encode Categorical Variables\nprint(\"\\nEncoding categorical variables...\")\n\n# Separate features and target\nX = train_fe.drop(['id', 'diagnosed_diabetes'], axis=1)\ny = train_fe['diagnosed_diabetes']\nX_test = test_fe.drop(['id'], axis=1)\n\n# Identify categorical columns\ncat_cols = X.select_dtypes(include=['object', 'category']).columns.tolist()\nprint(f\"Categorical columns: {cat_cols}\")\n\n# Label encode categorical features\nlabel_encoders = {}\nfor col in cat_cols:\n    le = LabelEncoder()\n    X[col] = le.fit_transform(X[col].astype(str))\n    X_test[col] = le.transform(X_test[col].astype(str))\n    label_encoders[col] = le\n\nprint(f\"Final feature shape: {X.shape}\")\n\n# %% [markdown]\n# # 🤖 Model Training with Cross-Validation\n\n# %% XGBoost with Cross-Validation\nprint(\"\\n\" + \"=\"*80)\nprint(\"TRAINING XGBOOST MODEL WITH 5-FOLD CV\")\nprint(\"=\"*80)\n\n# XGBoost parameters\nparams = {\n    'objective': 'binary:logistic',\n    'eval_metric': 'auc',\n    'max_depth': 6,\n    'learning_rate': 0.05,\n    'subsample': 0.8,\n    'colsample_bytree': 0.8,\n    'min_child_weight': 3,\n    'gamma': 0.1,\n    'reg_alpha': 0.1,\n    'reg_lambda': 1.0,\n    'random_state': RANDOM_STATE,\n    'tree_method': 'hist',\n    'n_jobs': -1\n}\n\n# Cross-validation setup\nn_splits = 5\nskf = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=RANDOM_STATE)\n\n# Store predictions and scores\noof_predictions = np.zeros(len(X))\ntest_predictions = np.zeros(len(X_test))\ncv_scores = []\n\n# Training loop\nfor fold, (train_idx, val_idx) in enumerate(skf.split(X, y), 1):\n    print(f\"\\n{'='*60}\")\n    print(f\"Fold {fold}/{n_splits}\")\n    print(f\"{'='*60}\")\n    \n    X_train, X_val = X.iloc[train_idx], X.iloc[val_idx]\n    y_train, y_val = y.iloc[train_idx], y.iloc[val_idx]\n    \n    # Create DMatrix\n    dtrain = xgb.DMatrix(X_train, label=y_train)\n    dval = xgb.DMatrix(X_val, label=y_val)\n    \n    # Train model\n    model = xgb.train(\n        params,\n        dtrain,\n        num_boost_round=1000,\n        evals=[(dtrain, 'train'), (dval, 'val')],\n        early_stopping_rounds=50,\n        verbose_eval=100\n    )\n    \n    # Predict on validation set\n    val_preds = model.predict(dval)\n    oof_predictions[val_idx] = val_preds\n    \n    # Calculate ROC AUC\n    fold_score = roc_auc_score(y_val, val_preds)\n    cv_scores.append(fold_score)\n    print(f\"\\nFold {fold} ROC AUC: {fold_score:.6f}\")\n    \n    # Predict on test set\n    dtest = xgb.DMatrix(X_test)\n    test_predictions += model.predict(dtest) / n_splits\n\n# Overall CV score\noverall_score = roc_auc_score(y, oof_predictions)\nprint(f\"\\n{'='*60}\")\nprint(f\"Overall CV ROC AUC: {overall_score:.6f}\")\nprint(f\"Std Dev: {np.std(cv_scores):.6f}\")\nprint(f\"{'='*60}\")\n\n# %% [markdown]\n# # 📈 Model Evaluation\n\n# %% ROC Curve\nfpr, tpr, thresholds = roc_curve(y, oof_predictions)\n\nplt.figure(figsize=(10, 6))\nplt.plot(fpr, tpr, color='darkorange', lw=2, label=f'ROC curve (AUC = {overall_score:.4f})')\nplt.plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--', label='Random Classifier')\nplt.xlim([0.0, 1.0])\nplt.ylim([0.0, 1.05])\nplt.xlabel('False Positive Rate', fontsize=12)\nplt.ylabel('True Positive Rate', fontsize=12)\nplt.title('Receiver Operating Characteristic (ROC) Curve', fontsize=14, fontweight='bold')\nplt.legend(loc=\"lower right\", fontsize=11)\nplt.grid(alpha=0.3)\nplt.tight_layout()\nplt.show()\n\n# %% Prediction Distribution\nfig, axes = plt.subplots(1, 2, figsize=(14, 5))\n\naxes[0].hist(oof_predictions[y == 0], bins=50, alpha=0.7, label='Class 0', color='green', edgecolor='black')\naxes[0].hist(oof_predictions[y == 1], bins=50, alpha=0.7, label='Class 1', color='red', edgecolor='black')\naxes[0].set_xlabel('Predicted Probability', fontsize=12)\naxes[0].set_ylabel('Frequency', fontsize=12)\naxes[0].set_title('OOF Predictions Distribution by Class', fontsize=14, fontweight='bold')\naxes[0].legend()\naxes[0].grid(alpha=0.3)\n\naxes[1].hist(test_predictions, bins=50, alpha=0.7, color='steelblue', edgecolor='black')\naxes[1].set_xlabel('Predicted Probability', fontsize=12)\naxes[1].set_ylabel('Frequency', fontsize=12)\naxes[1].set_title('Test Predictions Distribution', fontsize=14, fontweight='bold')\naxes[1].grid(alpha=0.3)\n\nplt.tight_layout()\nplt.show()\n\n# %% Feature Importance\n# Train final model on full data to get feature importance\nprint(\"\\nCalculating feature importance...\")\ndtrain_full = xgb.DMatrix(X, label=y)\nfinal_model = xgb.train(\n    params,\n    dtrain_full,\n    num_boost_round=model.best_iteration,\n    verbose_eval=False\n)\n\n# Get feature importance\nimportance = final_model.get_score(importance_type='gain')\nimportance_df = pd.DataFrame({\n    'feature': importance.keys(),\n    'importance': importance.values()\n}).sort_values('importance', ascending=False).head(20)\n\nplt.figure(figsize=(10, 8))\nplt.barh(importance_df['feature'], importance_df['importance'], color='teal')\nplt.xlabel('Importance (Gain)', fontsize=12)\nplt.ylabel('Features', fontsize=12)\nplt.title('Top 20 Most Important Features', fontsize=14, fontweight='bold')\nplt.gca().invert_yaxis()\nplt.tight_layout()\nplt.show()\n\nprint(\"\\nTop 20 Features:\")\nprint(importance_df.to_string(index=False))\n\n# %% [markdown]\n# # 📤 Create Submission File\n\n# %% Submission\nprint(\"\\n\" + \"=\"*80)\nprint(\"CREATING SUBMISSION FILE\")\nprint(\"=\"*80)\n\nsubmission['diagnosed_diabetes'] = test_predictions\n\nprint(f\"\\nSubmission shape: {submission.shape}\")\nprint(\"\\nSubmission preview:\")\nprint(submission.head(10))\n\nprint(f\"\\nPrediction statistics:\")\nprint(f\"Mean: {test_predictions.mean():.6f}\")\nprint(f\"Median: {np.median(test_predictions):.6f}\")\nprint(f\"Min: {test_predictions.min():.6f}\")\nprint(f\"Max: {test_predictions.max():.6f}\")\n\n# Save submission\nsubmission.to_csv('submission.csv', index=False)\nprint(\"\\n✅ Submission file saved as 'submission.csv'\")\nprint(f\"Expected Public LB Score (approximate): {overall_score:.6f}\")\nprint(\"\\n\" + \"=\"*80)\nprint(\"DONE! Good luck with your submission! 🚀\")\nprint(\"=\"*80)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-06T13:56:33.974227Z","iopub.execute_input":"2025-12-06T13:56:33.974581Z","iopub.status.id