ernal)\nSESSION_TYPE   = \"R\"                          # race sessions\nSEED=42; N_SPLITS=5; TARGET=\"PitNextLap\"\nLGB_SEEDS=(42,2024)\nMAX_ROUNDS_PER_YEAR = 30                      # safety cap\nprint(\"Will pull FastF1 seasons:\", SEASONS_FASTF1)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-26T05:29:39.867318Z","iopub.execute_input":"2026-05-26T05:29:39.867750Z","iopub.status.idle":"2026-05-26T05:29:39.880072Z","shell.execute_reply.started":"2026-05-26T05:29:39.867707Z","shell.execute_reply":"2026-05-26T05:29:39.878896Z"}},"outputs":[{"name":"stdout","text":"Will pull FastF1 seasons: [2018, 2019, 2020, 2021]\n","output_type":"stream"}],"execution_count":1},{"id":"a43f6230-ebd3-414b-ba2e-d59a9177d1d0","cell_type":"code","source":"import sys, subprocess\ntry:\n    import fastf1\nexcept Exception:\n    subprocess.run([sys.executable,\"-m\",\"pip\",\"install\",\"-q\",\"fastf1\"], check=False)\n    import fastf1\nimport os, gc, warnings, numpy as np, pandas as pd\nwarnings.filterwarnings(\"ignore\")\nos.makedirs(\"/kaggle/working/ff1cache\", exist_ok=True)\ntry: fastf1.Cache.enable_cache(\"/kaggle/working/ff1cache\")\nexcept Exception as e: print(\"cache warn:\",e)\nprint(\"fastf1\", getattr(fastf1,\"__version__\",\"?\"))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-26T05:29:39.882156Z","iopub.execute_input":"2026-05-26T05:29:39.883221Z","iopub.status.idle":"2026-05-26T05:29:51.561744Z","shell.execute_reply.started":"2026-05-26T05:29:39.883163Z","shell.execute_reply":"2026-05-26T05:29:51.560861Z"}},"outputs":[{"name":"stdout","text":"   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ 136.0/136.0 kB 5.5 MB/s eta 0:00:00\n   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ 70.6/70.6 kB 3.7 MB/s eta 0:00:00\n   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ 3.1/3.1 MB 59.8 MB/s eta 0:00:00\n   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ 55.6/55.6 kB 2.4 MB/s eta 0:00:00\n   ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ 73.1/73.1 kB 3.5 MB/s eta 0:00:00\nfastf1 3.8.3\n","output_type":"stream"}],"execution_count":2},{"id":"e791060b-8c84-4690-b34d-e63251ccc7a7","cell_type":"code","source":"# ---- Pull real F1 laps via FastF1 (defensive: skips any session that fails) ----\ndef pull_season(year):\n    rows=[]\n    try:\n        sched=fastf1.get_event_schedule(year, include_testing=False)\n        rounds=[int(r) for r in sched[\"RoundNumber\"].tolist() if int(r)>=1]\n    except Exception as e:\n        print(f\"  {year}: schedule failed: {e}\"); return pd.DataFrame()\n    for rnd in rounds[:MAX_ROUNDS_PER_YEAR]:\n        try:\n            ses=fastf1.get_session(year,rnd,SESSION_TYPE)\n            ses.load(laps=True, telemetry=False, weather=False, messages=False)\n            L=ses.laps\n            if L is None or len(L)==0: continue\n            ev=ses.event[\"EventName\"]\n            df=pd.DataFrame({\n                \"Driver\":L[\"Driver\"].astype(str).values,\n                \"Compound\":L[\"Compound\"].astype(str).values,\n                \"Race\":ev, \"Year\":year,\n                \"LapNumber\":pd.to_numeric(L[\"LapNumber\"],errors=\"coerce\").values,\n                \"Stint\":pd.to_numeric(L[\"Stint\"],errors=\"coerce\").values,\n                \"TyreLife\":pd.to_numeric(L[\"TyreLife\"],errors=\"coerce\").values,\n                \"Position\":pd.to_numeric(L[\"Position\"],errors=\"coerce\").values,\n                \"LapTime (s)\":L[\"LapTime\"].dt.total_seconds().values,\n                \"PitStop\":L[\"PitInTime\"].notna().astype(int).values,\n            })\n            rows.append(df)\n        except Exception as e:\n            print(f\"  {year} R{rnd}: skip ({type(e).__name__})\")\n    out=pd.concat(rows,ignore_index=True) if rows else pd.DataFrame()\n    print(f\"  {year}: {len(out)} laps from {len(rows)} races\")\n    return out\n\nff_parts=[pull_season(y) for y in SEASONS_FASTF1]\nff_raw=pd.concat([p for p in ff_parts if len(p)],ignore_index=True) if any(len(p) for p in ff_parts) else pd.DataF