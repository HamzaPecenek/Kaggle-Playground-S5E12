,"metadata":{}},{"id":"d3d9d6ee-794c-452e-9ad8-b25dddfd1892","cell_type":"code","source":"# ---- Load competition + existing external ----\nCAND=[\"/kaggle/input/playground-series-s6e5\",\"/kaggle/input/competitions/playground-series-s6e5\",\".\"]\nCBASE=next((p for p in CAND if os.path.exists(os.path.join(p,\"train.csv\"))),\".\")\ntrain=pd.read_csv(f\"{CBASE}/train.csv\"); test=pd.read_csv(f\"{CBASE}/test.csv\"); sample=pd.read_csv(f\"{CBASE}/sample_submission.csv\")\nimport glob\neh=glob.glob(\"/kaggle/input/**/f1_strategy_dataset*.csv\",recursive=True)+glob.glob(\"./f1_strategy_dataset*.csv\")\nexternal=pd.read_csv(eh[0]) if eh else None\nprint(\"train\",train.shape,\"| external\",None if external is None else external.shape)\n\nVALID_COMP={\"SOFT\",\"MEDIUM\",\"HARD\",\"INTERMEDIATE\",\"WET\"}\ndef clean_ff(df):\n    if df is None or len(df)==0: return None\n    df=df.copy()\n    df[\"Compound\"]=df[\"Compound\"].str.upper().str.strip()\n    df=df[df[\"Compound\"].isin(VALID_COMP)]\n    df=df.dropna(subset=[\"LapNumber\",\"LapTime (s)\"])\n    df[\"Stint\"]=df[\"Stint\"].fillna(1); df[\"TyreLife\"]=df[\"TyreLife\"].fillna(df[\"LapNumber\"])\n    df[\"Position\"]=df[\"Position\"].fillna(20)\n    df=df[(df[\"LapTime (s)\"]>40)&(df[\"LapTime (s)\"]<300)]   # drop junk/SC laps extremes\n    for c in [\"LapNumber\",\"Stint\",\"TyreLife\",\"Position\"]: df[c]=df[c].astype(int)\n    # derive PitNextLap from the sequence\n    df=df.sort_values([\"Driver\",\"Race\",\"Year\",\"LapNumber\"]).reset_index(drop=True)\n    df[\"PitNextLap\"]=df.groupby([\"Driver\",\"Race\",\"Year\"],sort=False)[\"PitStop\"].shift(-1).fillna(0).astype(int)\n    return df\nff=clean_ff(ff_raw if 'ff_raw' in dir() else None)\nprint(\"FastF1 usable laps after cleaning:\", 0 if ff is None else len(ff))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-26T05:35:09.500851Z","iopub.execute_input":"2026-05-26T05:35:09.501203Z","iopub.status.idle":"2026-05-26T05:35:11.540204Z","shell.execute_reply.started":"2026-05-26T05:35:09.501175Z","shell.execute_reply":"2026-05-26T05:35:11.539199Z"}},"outputs":[{"name":"stdout","text":"train (439140, 16) | external (101371, 16)\nFastF1 usable laps after cleaning: 46932\n","output_type":"stream"}],"execution_count":4},{"id":"e307d913-5b97-481f-aca3-cdc3f78af933","cell_type":"code","source":"COMP_ORD={\"SOFT\":0,\"MEDIUM\":1,\"HARD\":2,\"INTERMEDIATE\":3,\"WET\":4}\n_sl=(train.sort_values([\"Driver\",\"Race\",\"Year\",\"Stint\",\"LapNumber\"]).groupby([\"Driver\",\"Race\",\"Year\",\"Stint\"])\n        .agg(slen=(\"TyreLife\",\"max\"),comp=(\"Compound\",\"first\")).reset_index())\nCOMP_STINT=_sl.groupby(\"comp\")[\"slen\"].mean().to_dict()\nRACE_LEN=(pd.concat([train[[\"Race\",\"Year\",\"LapNumber\"]],test[[\"Race\",\"Year\",\"LapNumber\"]]]).groupby([\"Race\",\"Year\"])[\"LapNumber\"].max().to_dict())\nRL_MED=int(np.median(list(RACE_LEN.values())))\n\ndef build_features(df):\n    df=df.copy(); df[\"Compound\"]=df[\"Compound\"].fillna(\"MEDIUM\")\n    df=df.sort_values([\"Driver\",\"Race\",\"Year\",\"LapNumber\"]).reset_index(drop=True)\n    g=df.groupby([\"Driver\",\"Race\",\"Year\"],sort=False); lt=df[\"LapTime (s)\"]\n    # RECOMPUTED consistently for all datasets\n    df[\"LapTime_Delta\"]=(lt-g[\"LapTime (s)\"].shift(1)).fillna(0).astype(\"float32\")\n    df[\"Cumulative_Degradation\"]=df.groupby([\"Driver\",\"Race\",\"Year\",\"Stint\"],sort=False)[\"LapTime_Delta\"].cumsum().astype(\"float32\")\n    df[\"Position_Change\"]=(df[\"Position\"]-g[\"Position\"].shift(1)).fillna(0).astype(\"float32\")\n    ml=df.groupby([\"Race\",\"Year\"])[\"LapNumber\"].transform(\"max\")\n    df[\"RaceProgress\"]=(df[\"LapNumber\"]/ml).astype(\"float32\")\n    # standard features\n    df[\"comp_ord\"]=df[\"Compound\"].map(COMP_ORD).astype(\"float32\")\n    df[\"comp_exp_stint\"]=df[\"Compound\"].map(COMP_STINT).astype(\"float32\")\n    df[\"tyre_life_ratio\"]=(df[\"TyreLife\"]/df[\"comp_exp_stint\"]).astype(\"float32\")\n 