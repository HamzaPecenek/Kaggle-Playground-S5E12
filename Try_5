round=8000,valid_sets=[lgb.Dataset(Xva,yva)],\n                    callbacks=[lgb.early_stopping(200),lgb.log_evaluation(0)])\n        vp+=m.predict(Xva)/len(seeds); tp+=m.predict(Xte)/len(seeds)\n    return vp,tp\n\ny=train_fe[TARGET].values.astype(\"int8\")\ndef run_cv(aug_frames,tag):\n    oof=np.zeros(len(train_fe)); pred=np.zeros(len(test_fe))\n    skf=StratifiedKFold(n_splits=N_SPLITS,shuffle=True,random_state=SEED)\n    for fold,(tri,vai) in enumerate(skf.split(train_fe,y)):\n        tr=pd.concat([train_fe.iloc[tri]]+aug_frames,ignore_index=True)\n        ytr=tr[TARGET].values.astype(\"int8\")\n        enc,glob=smoothed_te(tr,\"Driver\",TARGET,50.0)\n        def mat(fr):\n            X=fr[BASE_NUM].copy(); X[\"Driver_te\"]=fr[\"Driver\"].map(enc).fillna(glob).values.astype(\"float32\"); return X.values\n        vp,tp=fit_lgb(mat(tr),ytr,mat(train_fe.iloc[vai]),y[vai],mat(test_fe))\n        oof[vai]=vp; pred+=tp/N_SPLITS\n        print(f\"  [{tag}] fold {fold+1}: {roc_auc_score(y[vai],vp):.5f}\",flush=True)\n        gc.collect()\n    return roc_auc_score(y,oof),pred\n\next_list=[ext_fe] if ext_fe is not None else []\nff_list =[ff_fe]  if ff_fe  is not None else []\nauc_base,pred_base=run_cv(ext_list,\"external-only\")\nprint(f\"\\nexternal-only OOF AUC = {auc_base:.5f}\")\nif ff_fe is not None:\n    auc_ff,pred_ff=run_cv(ext_list+ff_list,\"external+FastF1\")\n    print(f\"external+FastF1 OOF AUC = {auc_ff:.5f}   (delta {auc_ff-auc_base:+.5f})\")\nelse:\n    auc_ff=-1.0; pred_ff=None; print(\"No FastF1 data available — skipping the +FastF1 arm.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-26T05:35:14.054594Z","iopub.execute_input":"2026-05-26T05:35:14.054945Z","iopub.status.idle":"2026-05-26T06:04:26.350944Z","shell.execute_reply.started":"2026-05-26T05:35:14.054908Z","shell.execute_reply":"2026-05-26T06:04:26.349833Z"}},"outputs":[{"name":"stdout","text":"Training until validation scores don't improve for 200 rounds\nEarly stopping,