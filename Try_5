\":2,\"INTERMEDIATE\":3,\"WET\":4}\n_sl=(train.sort_values([\"Driver\",\"Race\",\"Year\",\"Stint\",\"LapNumber\"])\n        .groupby([\"Driver\",\"Race\",\"Year\",\"Stint\"]).agg(slen=(\"TyreLife\",\"max\"),comp=(\"Compound\",\"first\")).reset_index())\nCOMP_STINT=_sl.groupby(\"comp\")[\"slen\"].mean().to_dict()\nRACE_LEN=(pd.concat([train[[\"Race\",\"Year\",\"LapNumber\"]],test[[\"Race\",\"Year\",\"LapNumber\"]]])\n            .groupby([\"Race\",\"Year\"])[\"LapNumber\"].max().to_dict())\nRL_MED=int(np.median(list(RACE_LEN.values())))\n\ndef build_features(df):\n    df=df.copy(); df[\"Compound\"]=df[\"Compound\"].fillna(\"MEDIUM\")\n    df[\"comp_ord\"]=df[\"Compound\"].map(COMP_ORD).astype(\"float32\")\n    df[\"comp_exp_stint\"]=df[\"Compound\"].map(COMP_STINT).astype(\"float32\")\n    df[\"tyre_life_ratio\"]=(df[\"TyreLife\"]/df[\"comp_exp_stint\"]).astype(\"float32\")\n    df[\"race_len\"]=df.set_index([\"Race\",\"Year\"]).index.map(RACE_LEN).astype(\"float32\"); df[\"race_len\"]=df[\"race_len\"].fillna(RL_MED).astype(\"float32\")\n    df[\"laps_remaining\"]=(df[\"race_len\"]-df[\"LapNumber\"]).astype(\"float32\")\n    df[\"frac_remaining\"]=(df[\"laps_remaining\"]/df[\"race_len\"]).astype(\"float32\")\n    df[\"deg_per_lap\"]=(df[\"Cumulative_Degradation\"]/(df[\"TyreLife\"]+1)).astype(\"float32\")\n    df[\"tyrelife_x_prog\"]=(df[\"TyreLife\"]*df[\"RaceProgress\"]).astype(\"float32\")\n    df[\"tyrelife_x_ratio\"]=(df[\"TyreLife\"]*df[\"tyre_life_ratio\"]).astype(\"float32\")\n    df[\"stint_x_tyrelife\"]=(df[\"Stint\"]*df[\"TyreLife\"]).astype(\"float32\")\n    df[\"pos_norm\"]=(df[\"Position\"]/20.0).astype(\"float32\")\n    df=df.sort_values([\"Driver\",\"Race\",\"Year\",\"LapNumber\"])\n    g=df.groupby([\"Driver\",\"Race\",\"Year\"],sort=False); lt=df[\"LapTime (s)\"]\n    df[\"prev_pit\"]=g[\"PitStop\"].shift(1)\n    df[\"laptime_chg\"]=(lt-g[\"LapTime (s)\"].shift(1)).astype(\"float32\")\n    df[\"tyrelife_chg\"]=(df[\"TyreLife\"]-g[\"TyreLife\"].shift(1)).astype(\"float32\")\n    df[\"deg_chg\"]=(df[\"Cumulative_Degradation\"]-g[\"Cumulative_Degradation\"].shift(1)).astype(\"float32\")\n    df[\"laptime_vs_avg\"]=(lt-g[\"LapTime (s)\"].cumsum()/(g.cumcount()+1)).astype(\"float32\")\n    df[\"tl_round\"]=df[\"TyreLife\"].round().astype(\"int32\")\n    df[\"rp_bin\"]=(df[\"RaceProgress\"]*20).round().astype(\"int32\")\n    df[\"seq_len\"]=g[\"LapNumber\"].transform(\"size\").astype(\"float32\")\n    df[\"n_stints\"]=g[\"Stint\"].transform(\"nunique\").astype(\"float32\")\n    return df.reset_index(drop=True)\n\ntrain_fe=build_features(train); test_fe=build_features(test); ext_fe=build_features(ext_raw) if USE_EXTERNAL else None\nall_races=set(train[\"Race\"])|set(test[\"Race\"])\nif USE_EXTERNAL: all_races|=set(ext_raw[\"Race\"])\nrc=pd.CategoricalDtype(categories=sorted(all_races))\nfor d in [train_fe,test_fe]+([ext_fe] if USE_EXTERNAL else []): d[\"Race_cat\"]=d[\"Race\"].astype(rc).cat.codes.astype(\"int32\")\n\nBASE_NUM=[\"comp_ord\",\"TyreLife\",\"Stint\",\"Position\",\"LapNumber\",\"RaceProgress\",\"Position_Change\",\n          \"LapTime (s)\",\"LapTime_Delta\",\"Cumulative_Degradation\",\"PitStop\",\"Year\",\n          \"comp_exp_stint\",\"tyre_life_ratio\",\"race_len\",\"laps_remaining\",\"frac_remaining\",\n          \"deg_per_lap\",\"tyrelife_x_prog\",\"tyrelife_x_ratio\",\"stint_x_tyrelife\",\"pos_norm\",\n          \"prev_pit\",\"laptime_chg\",\"tyrelife_chg\",\"deg_chg\",\"laptime_vs_avg\",\"Race_cat\"]\nCOUNT_FEATS=[\"seq_len\",\"n_stints\"]\nRICH_KEYS={\"te_race_lap\":[\"Race_cat\",\"Year\",\"LapNumber\"],\"te_comp_tl\":[\"comp_ord\",\"tl_round\"],\n           \"te_comp_stint\":[\"comp_ord\",\"Stint\"],\"te_driver_comp\":[\"Driver\",\"comp_ord\"],\n           \"te_year_rp\":[\"Year\",\"rp_bin\"],\"te_race_stint\":[\"Race_cat\",\"Stint\"]}\nprint(\"BASE\",len(BASE_NUM),\"+Driver_te | RICH adds\",len(RICH_KEYS),\"OOF target-encodings +\",len(COUNT_FEATS),\"counts\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-25T19:17:50.175443Z","iopub.execute_input":"2026-05-25T19:17:50.175793Z","iopub.status.idle":"2026-05-25T19:17:52.248123Z","shell.execute_reply.started":"2026-05-25T19:17:50.175757Z","shell.execute_reply":"2026-05-25T19:17:52.247340Z"}},"outputs":[{"name":"stdout","text":"BASE 28 +Driver_te | RICH adds 6 OOF target-encodings + 2 counts\n","output_type":"stream"}],"execution_count":3},{"id":"e6d25c9a-c71a-4d3a-ad4f-552d88bfe108","cell_type":"markdown","source":"## Leak-free encoding + model\n`encode_features` does **out-of-fold** target encoding for training rows (inner KFold) and full-fit encoding for val/test — so no row ever sees its own label.","metadata":{}},{"id":"d898f818-ecdb-4077-bcc1-721d467a9e91","cell_type":"code","source":"def _enc_map(frame, keys, enc, glob):\n    if len(keys)==1: return frame[keys[0]].map(enc).fillna(glob).astype(\"float32\").values\n    return pd.Series(list(zip(*[frame[k].values for k in keys]))).map(enc).fillna(glob).astype(\"float32\").values\n\ndef _fit_enc(frame, keys, target, glob, m):\n    agg=frame.groupby(keys)[target].agg([\"mean\",\"count\"])\n    return ((agg[\"mean\"]*agg[\"count\"]+glob*m)/(agg[\"count\"]+m)).to_dict()\n\ndef encode_features(tr_all, va, te, keysets, base_num, count_feats, m=30.0, n_inner=5, seed=SEED):\n    glob=tr_all[TARGET].mean(); n=len(tr_all)\n    oof={nm:np.full(n,glob,dtype=\"float32\") for nm in keysets}\n    kf=KFold(n_inner,shuffle=True,random_state=seed)\n    for itr,iva in kf.split(np.arange(n)):\n        sub=tr_all.iloc[itr]; vv=tr_all.iloc[iva]\n        for nm,keys in keysets.items():\n            oof[nm][iva]=_enc_map(vv,keys,_fit_enc(sub,keys,TARGET,glob,m),glob)\n    full={nm:(keys,_fit_enc(tr_all,keys,TARGET,glob,m)) for nm,keys in keysets.items()}\n    Xtr=tr_all[base_num+count_feats].copy()\n    for nm in keysets: Xtr[nm]=oof[nm]\n    Xva=va[base_num+count_feats].copy(); Xte=te[base_num+count_feats].copy()\n    for nm,(keys,enc) in full.items():\n        Xva[nm]=_enc_map(va,keys,enc,glob); Xte[nm]=_enc_map(te,keys,enc,glob)\n    return Xtr,Xva,Xte\n\ndef fit_lgb(Xtr,ytr,Xva,yva,Xte,seeds=LGB_SEEDS):\n    vp=np.zeros(len(yva)); tp=np.zeros(len(Xte)); imp=None\n    for s in seeds:\n        p=dict(objective=\"binary\",metric=\"auc\",learning_rate=0.02,num_leaves=320,feature_fraction=0.65,\n               bagging_fraction=0.85,bagging_freq=1,min_child_samples=80,lambda_l1=1.5,lambda_l2=3.0,\n               max_bin=255,verbose=-1,n_jobs=-1,seed=s)\n        m=lgb.train(p,lgb.Dataset(Xtr,ytr),num_boost_round=8000,valid_sets=[lgb.Dataset(Xva,yva)],\n                    callbacks=[lgb.early_stopping(200),lgb.log_evaluation(0)])\n        vp+=m.predict(Xva)/len(seeds); tp+=m.predict(Xte)/len(seeds)\n        fi=m.feature_importance(importance_type=\"gain\"); imp=fi if imp is None else imp+fi\n    return vp,tp,imp/len(seeds)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-25T19:17:52.250215Z","iopub.execute_input":"2026-05-25T19:17:52.250545Z","iopub.status.idle":"2026-05-25T19:17:52.264186Z","shell.execute_reply.started":"2026-05-25T19:17:52.250518Z","shell.execute_reply":"2026-05-25T19:17:52.263475Z"}},"outputs":[],"execution_count":4},{"id":"e77e6c0f-a17f-4cbf-8846-b94b62fcce0a","cell_type":"markdown","source":"## A/B cross-validation — BASE vs RICH (full data, leak-free OOF encodings)","metadata":{}},{"id":"dbdcb419-0e9f-4b40-846b-554ea0ec1ac2","cell_type":"code","source":"y=train_fe[TARGET].values.astype(\"int8\"); nte=len(test_fe)\noof_b=np.zeros(len(train_fe)); oof_r=np.zeros(len(train_fe)); pred_b=np.zeros(nte); pred_r=np.zeros(nte)\nBASE_KEYS={\"Driver_te\":[\"Driver\"]}\nRICH_ALL={**BASE_KEYS, **RICH_KEYS}\nRICH_COLS=BASE_NUM+COUNT_FEATS+list(RICH_ALL.keys())\nimp_acc=np.zeros(len(RICH_COLS))\nskf=StratifiedKFold(n_splits=N_SPLITS,shuffle=True,random_state=SEED)\nfor fold,(tri,vai) in enumerate(skf.split(train_fe,y)):\n    tr_syn=train_fe.iloc[tri]\n    tr_all=pd.concat([tr_syn,ext_fe],ignore_index=True) if (USE_EXTERNAL and ext_fe is not None) else tr_syn\n    ytr=tr_all[TARGET].values.astype(\"int8\"); va=train_fe.iloc[vai]; yva=y[vai]\n    # BASE\n    bXtr,bXva,bXte=encode_features(tr_all,va,test_fe,BASE_KEYS,BASE_NUM,[])\n    vp,tp,_=fit_lgb(bXtr.values,ytr,bXva.values,yva,bXte.values); oof_b[vai]=vp; pred_b+=tp/N_SPLITS\n    del bXtr,bXva,bXte; gc.collect()\n    # RICH\n    rXtr,rXva,rXte=encode_features(tr_all,va,test_fe,RICH_ALL,BASE_NUM,COUNT_FEATS)\n    rXtr=rXtr[RICH_COLS]; rXva=rXva[RICH_COLS]; rXte=rXte[RICH_COLS]\n    vp,tp,imp=fit_lgb(rXtr.values,ytr,rXva.values,yva,rXte.values); oof_r[vai]=vp; pred_r+=tp/N_SPLITS; imp_acc+=imp/N_SPLITS\n    print(f\"fold {fold+1}: base={roc_auc_score(yva,oof_b[vai]):.5f} | rich={roc_auc_score(yva,oof_r[vai]):.5f}\", flush=True)\n    del rXtr,rXva,rXte,tr_all; gc.collect()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-25T19:17:52.265186Z","iopub.execute_input":"2026-05-25T19:17:52.265520Z","iopub.status.idle":"2026-05-25T20:00:08.754810Z","shell.execute_reply.started":"2026-05-25T19:17:52.265482Z","shell.execute_reply":"2026-05-25T20:00:08.753972Z"}},"outputs":[{"name":"stdout","text":"Training until validation scores don't improve for 200 rounds\nEarly stopping, best iteration is:\n[1116]\tvalid_0's auc: 0.951632\nTraining until validation scores don't improve for 200 rounds\nEarly stopping, best iteration is:\n[915]\tvalid_0's auc: 0.951664\nTraining until validation scores don't improve for 200 rounds\nEarly stopping, best iteration is:\n[1064]\tvalid_0's auc: 0.951431\nTraining until validation scores don't improve for 200 rounds\nEarly stopping, best iteration is:\n[1150]\tvalid_0's auc: 0.951551\nfold 1: base=0.95181 | rich=0.95166\nTraining until validation scores don't improve for 200 rounds\nEarly stopping, best iteration is:\n[1087]\tvalid_0's auc: 0.950934\nTraining until validation scores don't improve for 200 rounds\nEarly stopping, best iteration is:\n[1136]\tvalid_0