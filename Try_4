       feature_fraction=t.suggest_float(\"feature_fraction\",0.5,0.9),\n               bagging_fraction=t.suggest_float(\"bagging_fraction\",0.6,0.95),\n               min_child_samples=t.suggest_int(\"min_child_samples\",30,150),\n               lambda_l1=t.suggest_float(\"lambda_l1\",0.0,5.0),\n               lambda_l2=t.suggest_float(\"lambda_l2\",0.0,8.0))\n        m=lgb.train(p,dtr,num_boost_round=3000,valid_sets=[dva],\n                    callbacks=[lgb.early_stopping(120),lgb.log_evaluation(0)])\n        return roc_auc_score(yva,m.predict(Ava))\n    st=optuna.create_study(direction=\"maximize\"); st.optimize(obj,n_trials=30,show_progress_bar=False)\n    print(\"best AUC:\",round(st.best_value,5)); print(\"best params:\",st.best_params)\nelse:\n    print(\"USE_OPTUNA=False — skipping tuning search.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-25T11:30:18.718411Z","iopub.execute_input":"2026-05-25T11:30:18.719002Z"}},"outputs":[{"name":"stdout","text":"Training until validation scores don't improve for 120 rounds\nEarly stopping, best iteration is:\n[537]\tvalid_0's auc: 0.950819\nTraining until validation scores don't improve for 120 rounds\nEarly stopping, best iteration is:\n[739]\tvalid_0's auc: 0.951435\nTraining until validation scores don't improve for 120 rounds\nEarly stopping, best iteration is:\n[648]\tvalid_0's auc: 0.950923\n","output_type":"stream"},{"name":"stderr","text":"[LightGBM] [Fatal] Reducing `min_data_in_leaf` with `feature_pre_filter=true` may cause unexpected behaviour for features that were pre-filtered by the larger `min_data_in_leaf`.\nYou need to set `feature_pre_filter=false` to dynamically change the `min_data_in_leaf`.\n[LightGBM] [Fatal] Reducing `min_data_in_leaf` with `feature_pre_filter=true` may cause unexpected behaviour for features that were pre-filtered by the larger `min_data_in_leaf`.\nYou need to set `feature_pre_filter=false` to dynamically change the `min_data_in_leaf`.\n","output_type"