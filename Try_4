\":3000,\"xatol\":1e-4,\"fatol\":1e-6})\n    if best is None or res.fun<best.fun: best=res\nw=np.clip(best.x,0,None); w=w/w.sum()\nw_auc=roc_auc_score(y, Mtr@w)\n\nprint(\"\\nequal-weight rank-blend OOF AUC :\", round(eq_auc,5))\nprint(\"optimized weights:\", {models[i]:round(float(w[i]),3) for i in range(len(models))})\nprint(\"weighted rank-blend OOF AUC     :\", round(w_auc,5))\nUSE_W = w_auc >= eq_auc\nprint(\"\\n>>> using\", \"OPTIMIZED weights\" if USE_W else \"EQUAL weights\",\n      \"| final OOF AUC =\", round(max(w_auc,eq_auc),5))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-25T11:19:19.743933Z","iopub.execute_input":"2026-05-25T11:19:19.744263Z","iopub.status.idle":"2026-05-25T11:24:31.146205Z","shell.execute_reply.started":"2026-05-25T11:19:19.744238Z","shell.execute_reply":"2026-05-25T11:24:31.145296Z"}},"outputs":[{"name":"stdout","text":"Per-model OOF AUC:\n   lgb: 0.95086\n   xgb: 0.95031\n   cat: 0.94873\n   nn: 0.93815\n\nequal-weight rank-blend OOF AUC : 0.94966\noptimized weights: {'lgb': 0.836, 'xgb': 0.109, 'cat': 0.055, 'nn': 0.0}\nweighted rank-blend OOF AUC     : 0.95088\n\n>>> using OPTIMIZED weights | final OOF AUC = 0.95088\n","output_type":"stream"}],"execution_count":6},{"id":"f1dcba67-b163-4052-a809-3273d213de5b","cell_type":"code","source":"# ---- Submission from chosen blend (id-aligned) ----\nRte = {k: rankdata(pred[k])/len(pred[k]) for k in models}\nMte = np.vstack([Rte[k] for k in models]).T\nfinal = (Mte@w) if USE_W else np.mean([Rte[k] for k in models], axis=0)\n\npred_df = pd.DataFrame({\"id\": test_fe[\"id\"].values, TARGET: final})\nsample2 = pd.read_csv(f\"{BASE}/sample_submission.csv\")\nsubmission = sample2[[\"id\"]].merge(pred_df, on=\"id\", how=\"left\")\nassert submission[TARGET].isna().sum()==0 and (submission[\"id\"].values==sample2[\"id\"].values).all()\nsubmission.to_csv(\"submission.csv\", index=False)\nprint(\"saved submission.csv\", submission.shape, \"| id order verified\")\nprint(submis