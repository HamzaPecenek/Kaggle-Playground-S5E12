{"metadata":{"kernelspec":{"display_name":"Python 3","language":"python","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"}},"nbformat_minor":5,"nbformat":4,"cells":[{"id":"093a86af-0417-4fc6-8f5f-daf878d549bb","cell_type":"markdown","source":"# 🏎️ Predicting F1 Pit Stops — v3: Tuned GBDTs + Neural Net + Stacking\n**Playground S6E5** · Metric **ROC-AUC** · Target `PitNextLap`\n\nv2 reached LB ~0.9499 but the three GBDTs are highly correlated, so blending them barely helped. v3 attacks that two ways:\n\n1. **A neural-net (MLP)** trained on GPU — a fundamentally *different* model family, so its errors are decorrelated from the trees. This is what a saturated GBDT ensemble needs.\n2. **OOF-optimized stacking** instead of equal-weight blending — we learn the blend weights that maximize OOF AUC, so weak models can't drag the strong ones down.\n3. **Tuned** LightGBM / XGBoost / CatBoost, plus an **optional Optuna** cell.\n\nWe keep the two things that *worked*: **external-data augmentation** (+0.0046 OOF) and the **lean v1 feature set** (extra features only hurt).\n\n> **⚠️ Enable a GPU accelerator** (T4 x2 or P100) in notebook settings, then set `USE_GPU = True`. The neural net needs it; XGBoost/CatBoost also speed up. Without a GPU the NN will be slow — set `USE_NN = False` to skip it.\n>\n> **Add the external dataset** (the `f1_strategy_dataset_v4.csv`) via *Add Input → Datasets*, same as v2.","metadata":{}},{"id":"22fb5cf9-b33d-4617-9998-bff62ff107ae","cell_type":"code","source":"import os, gc, warnings, numpy as np, pandas as pd\nwarnings.filterwarnings(\"ignore\")\nfrom sklearn.model_selection import StratifiedKFold\nfrom sklearn.metrics import roc_auc_score\nfrom scipy.stats import rankdata\nfrom scipy.optimize import minimize\nimport lightgbm as lgb\n\nSEED         = 42\nN_SPLITS     = 5\nTARGET       = \"PitNextLap\"\nUSE_EXTERNAL = True\nUSE_GPU      = True     # set True ONLY if a GPU accelerator is enabled\nUSE_NN       = True     # neural net (needs GPU to be practical)\nUSE_OPTUNA   = True    # set True to run the optional tuning cell near the end\n\ntry:\n    import xgboost as xgb; HAS_XGB = True\nexcept Exception as e:\n    HAS_XGB = False; print(\"XGBoost unavailable:\", e)\ntry:\n    from catboost import CatBoostClassifier; HAS_CAT = True\nexcept Exception as e:\n    HAS_CAT = False; print(\"CatBoost unavailable:\", e)\ntry:\n    import torch, torch.nn as nn\n    HAS_TORCH = True\n    DEVICE = \"cuda\" if (USE_GPU and torch.cuda.is_available()) else \"cpu\"\nexcept Exception as e:\n    HAS_TORCH = False; DEVICE = \"cpu\"; print(\"PyTorch unavailable:\", e)\nprint(f\"LGBM {lgb.__version__} | XGB={HAS_XGB} | CatBoost={HAS_CAT} | Torch={HAS_TORCH} | device={DEVICE}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-25T11:26:19.476810Z","iopub.execute_input":"2026-05-25T11:26:19.477342Z","iopub.status.idle":"2026-05-25T11:26:19.485240Z","shell.execute_reply.started":"2026-05-25T11:26:19.477294Z","shell.execute_reply":"2026-05-25T11:26:19.484418Z"}},"outputs":[{"name":"stdout","text":"LGBM 4.6.0 | XGB=True | CatBoost=True | Torch=True | device=cuda\n","output_type":"stream"}],"execution_count":9},{"id":"f4d68d88-f8c2-40d1-8445-2aa0c493091d","cell_type":"code","source":"CAND = [\"/kaggle/input/playground-series-s6e5\",\n        \"/kaggle/input/competitions/playground-series-s6e5\", \".\"]\nBASE = next((p for p in CAND if os.path.exists(os.path.join(p,\"train.csv\"))), \".\")\ntrain  = pd.read_csv(f\"{BASE}/train.csv\")\ntest   = pd.read_csv(f\"{BASE}/test.csv\")\nsample = pd.read_csv(f\"{BASE}/sample_submission.csv\")\nprint(\"train\", train.shape, \"| test\", test.shape)\n\next_raw = None\nif USE_EXTERNAL:\n    import glob\n    hits = glob.glob(\"/kaggle/input/**/f1_strategy_dataset*.csv\", recursive=True) + glob.glob(\"./f1_strategy_dataset*.csv\")\n    if hits:\n        ext_raw = pd.read_csv(hits[0]); print(\"external:\", hits[0], ext_raw.shape)\n    else:\n        print(\"⚠️ external dataset not found — synthetic only.\"); USE_EXTERNAL = False","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-25T10:34:38.792835Z","iopub.execute_input":"2026-05-25T10:34:38.793555Z","iopub.status.idle":"2026-05-25T10:34:40.842252Z","shell.execute_reply.started":"2026-05-25T10:34:38.793527Z","shell.execute_reply":"2026-05-25T10:34:40.841490Z"}},"outputs":[{"name":"stdout","text":"train (439140, 16) | test (188165, 15)\nexternal: /kaggle/input/datasets/aadigupta1601/f1-strategy-dataset-pit-stop-prediction/f1_strategy_dataset_v4.csv (101371, 16)\n","output_type":"stream"}],"execution_count":2},{"id":"47cea8de-31ed-4240-9616-90577d1030ca","cell_type":"markdown","source":"## Features — the proven lean v1 set (applied to train, test, external)","metadata":{}},{"id":"1eb85719-4ce2-4d27-8a32-c2998aa20fb7","cell_type":"code","source":"COMP_ORD = {\"SOFT\":0,\"MEDIUM\":1,\"HARD\":2,\"INTERMEDIATE\":3,\"WET\":4}\n_sl = (train.sort_values([\"Driver\",\"Race\",\"Year\",\"Stint\",\"LapNumber\"])\n            .groupby([\"Driver\",\"Race\",\"Year\",\"Stint\"])\n            .agg(slen=(\"TyreLife\",\"max\"), comp=(\"Compound\",\"first\")).reset_index())\nCOMP_STINT = _sl.groupby(\"comp\")[\"slen\"].mean().to_dict()\nRACE_LEN   = (pd.concat([train[[\"Race\",\"Year\",\"LapNumber\"]], test[[\"Race\",\"Year\",\"LapNumber\"]]])\n                .groupby([\"Race\",\"Year\"])[\"LapNumber\"].max().to_dict())\nRL_MED = int(np.median(list(RACE_LEN.values())))\n\ndef build_features(df):\n    df = df.copy()\n    df[\"Compound\"]        = df[\"Compound\"].fillna(\"MEDIUM\")\n    df[\"comp_ord\"]        = df[\"Compound\"].map(COMP_ORD).astype(\"float32\")\n    df[\"comp_exp_stint\"]  = df[\"Compound\"].map(COMP_STINT).astype(\"float32\")\n    df[\"tyre_life_ratio\"] = (df[\"TyreLife\"]/df[\"comp_exp_stint\"]).astype(\"float32\")\n    df[\"race_len\"]        = df.set_index([\"Race\",\"Year\"]).index.map(RACE_LEN).astype(\"float32\")\n    df[\"race_len\"]        = df[\"race_len\"].fillna(RL_MED).astype(\"float32\")\n    df[\"laps_remaining\"]  = (df[\"race_len\"]-df[\"LapNumber\"]).astype(\"float32\")\n    df[\"frac_remaining\"]  = (df[\"laps_remaining\"]/df[\"race_len\"]).astype(\"float32\")\n    df[\"deg_per_lap\"]     = (df[\"Cumulative_Degradation\"]/(df[\"TyreLife\"]+1)).astype(\"float32\")\n    df[\"tyrelife_x_prog\"] = (df[\"TyreLife\"]*df[\"RaceProgress\"]).astype(\"float32\")\n    df[\"tyrelife_x_ratio\"]= (df[\"TyreLife\"]*df[\"tyre_life_ratio\"]).astype(\"float32\")\n    df[\"stint_x_tyrelife\"]= (df[\"Stint\"]*df[\"TyreLife\"]).astype(\"float32\")\n    df[\"pos_norm\"]        = (df[\"Position\"]/20.0).astype(\"float32\")\n    df = df.sort_values([\"Driver\",\"Race\",\"Year\",\"LapNumber\"])\n    g  = df.groupby([\"Driver\",\"Race\",\"Year\"], sort=False); lt = df[\"LapTime (s)\"]\n    df[\"prev_pit\"]      = g[\"PitStop\"].shift(1)\n    df[\"laptime_chg\"]   = (lt - g[\"LapTime (s)\"].shift(1)).astype(\"float32\")\n    df[\"tyrelife_chg\"]  = (df[\"TyreLife\"] - g[\"TyreLife\"].shift(1)).astype(\"float32\")\n    df[\"deg_chg\"]       = (df[\"Cumulative_Degradation\"] - g[\"Cumulative_Degradation\"].shift(1)).astype(\"float32\")\n    df[\"laptime_vs_avg\"]= (lt - g[\"LapTime (s)\"].cumsum()/(g.cumcount()+1)).astype(\"float32\")\n    return df.reset_index(drop=True)\n\ntrain_fe = build_features(train)\ntest_fe  = build_features(test)\next_fe   = build_features(ext_raw) if USE_EXTERNAL else None\n\nall_races = set(train[\"Race\"]) | set(test[\"Race\"])\nif USE_EXTERNAL: all_races |= set(ext_raw[\"Race\"])\nrace_cats = pd.CategoricalDtype(categories=sorted(all_races))\nfor d in [train_fe, test_fe] + ([ext_fe] if USE_EXTERNAL else []):\n    d[\"Race_cat\"] = d[\"Race\"].astype(race_cats).cat.codes.astype(\"int32\")\n\nNUM_FEATS = [\"comp_ord\",\"TyreLife\",\"Stint\",\"Position\",\"LapNumber\",\"RaceProgress\",\"Position_Change\",\n             \"LapTime (s)\",\"LapTime_Delta\",\"Cumulative_Degradation\",\"PitStop\",\"Year\",\n             \"comp_exp_stint\",\"tyre_life_ratio\",\"race_len\",\"laps_remaining\",\"frac_remaining\",\n             \"deg_per_lap\",\"tyrelife_x_prog\",\"tyrelife_x_ratio\",\"stint_x_tyrelife\",\"pos_norm\",\n             \"prev_pit\",\"laptime_chg\",\"tyrelife_chg\",\"deg_chg\",\"laptime_vs_avg\",\"Race_cat\"]\nprint(len(NUM_FEATS)+1, \"features (+ Driver_te per fold); external rows:\", 0 if ext_fe is None else len(ext_fe))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-25T10:34:40.843420Z","iopub.execute_input":"2026-05-25T10:34:40.843812Z","iopub.status.idle":"2026-05-25T10:34:42.608197Z","shell.execute_reply.started":"2026-05-25T10:34:40.843786Z","shell.execute_reply":"2026-05-25T10:34:42.607534Z"}},"outputs":[{"name":"stdout","text":"29 features (+ Driver_te per fold); external rows: 101371\n","output_type":"stream"}],"execution_count":3},{"id":"c2a8a551-9ab5-4489-8133-8262a5b55fb4","cell_type":"markdown","source":"## Model trainers\nThree tuned GBDTs + a PyTorch MLP. The NN is wrapped defensively — if it errors, the notebook still finishes with a GBDT-only stack.","metadata":{}},{"id":"bdd87f20-faa1-4932-99ea-6f96eb9a0040","cell_type":"code","source":"def smoothed_te(frame, cat, target, m=50.0):\n    glob = frame[target].mean()\n    agg  = frame.groupby(cat)[target].agg([\"mean\",\"count\"])\n    return ((agg[\"mean\"]*agg[\"count\"] + glob*m)/(agg[\"count\"]+m)).to_dict(), glob\n\ndef fit_lgb(Xtr,ytr,Xva,yva,Xte,seeds=(42,2024,7)):\n    vp=np.zeros(len(yva)); tp=np.zeros(len(Xte))\n    for s in seeds:\n        p=dict(objective=\"binary\",metric=\"auc\",learning_rate=0.02,num_leaves=320,\n               feature_fraction=0.65,bagging_fraction=0.85,bagging_freq=1,min_child_samples=80,\n               lambda_l1=1.5,lambda_l2=3.0,max_bin=255,verbose=-1,n_jobs=-1,seed=s)\n        m=lgb.train(p,lgb.Dataset(Xtr,ytr),num_boost_round=8000,valid_sets=[lgb.Dataset(Xva,yva)],\n                    callbacks=[lgb.early_stopping(200),lgb.log_evaluation(0)])\n        vp+=m.predict(Xva)/len(seeds); tp+=m.predict(Xte)/len(seeds)\n    return vp,tp\n\ndef fit_xgb(Xtr,ytr,Xva,yva,Xte):\n    dtr=xgb.DMatrix(Xtr,label=ytr); dva=xgb.DMatrix(Xva,label=yva); dte=xgb.DMatrix(Xte)\n    p={\"objective\":\"binary:logistic\",\"eval_metric\":\"auc\",\"eta\":0.02,\"max_depth\":9,\n       \"subsample\":0.85,\"colsample_bytree\":0.65,\"min_child_weight\":6,\n       \"reg_lambda\":3.0,\"reg_alpha\":1.5,\"tree_method\":\"hist\",\"seed\":SEED}\n    if USE_GPU: p[\"device\"]=\"cuda\"\n    m=xgb.train(p,dtr,num_boost_round=8000,evals=[(dva,\"v\")],early_stopping_rounds=200,verbose_eval=False)\n    r=(0,m.best_iteration+1)\n    return m.predict(dva,iteration_range=r), m.predict(dte,iteration_range=r)\n\ndef fit_cat(Xtr,ytr,Xva,yva,Xte):\n    m=CatBoostClassifier(iterations=8000,learning_rate=0.025,depth=9,l2_leaf_reg=4.0,\n        loss_function=\"Logloss\",eval_metric=\"AUC\",random_seed=SEED,\n        task_type=(\"GPU\" if USE_GPU else \"CPU\"),verbose=False,early_stopping_rounds=200)\n    m.fit(Xtr,ytr,eval_set=(Xva,yva),use_best_model=True)\n    return m.predict_proba(Xva)[:,1], m.predict_proba(Xte)[:,1]\n\ndef fit_nn(Xtr,ytr,Xva,yva,Xte,epochs=40,bs=4096,seed=SEED):\n    torch.manual_seed(seed); np.random.seed(seed)\n    med = np.nanmedian(Xtr,axis=0); med=np.where(np.isnan(med),0.0,med)\n    def clean(A): \n        A=np.where(np.isnan(A),med,A).astype(\"float32\"); return A\n    Xtr,Xva,Xte = clean(Xtr),clean(Xva),clean(Xte)\n    mu=Xtr.mean(0); sd=Xtr.std(0)+1e-6\n    Xtr=(Xtr-mu)/sd; Xva=(Xva-mu)/sd; Xte=(Xte-mu)/sd\n    d=Xtr.shape[1]\n    net=nn.Sequential(nn.Linear(d,256),nn.BatchNorm1d(256),nn.SiLU(),nn.Dropout(0.30),\n                      nn.Linear(256,128),nn.BatchNorm1d(128),nn.SiLU(),nn.Dropout(0.20),\n                      nn.Linear(128,64),nn.SiLU(),nn.Dropout(0.10),nn.Linear(64,1)).to(DEVICE)\n    opt=torch.optim.Adam(net.parameters(),lr=1e-3,weight_decay=1e-5)\n    lossf=nn.BCEWithLogitsLoss()\n    Xtr_t=torch.tensor(Xtr); ytr_t=torch.tensor(ytr.astype(\"float32\"))\n    Xva_t=torch.tensor(Xva).to(DEVICE); Xte_t=torch.tensor(Xte).to(DEVICE)\n    n=len(Xtr_t); best_auc=-1; best_va=None; best_te=None; patience=0\n    for ep in range(epochs):\n        net.train(); perm=torch.randperm(n)\n        for i in range(0,n,bs):\n            idx=perm[i:i+bs]\n            if len(idx)<2: continue\n            xb=Xtr_t[idx].to(DEVICE); yb=ytr_t[idx].to(DEVICE)\n            opt.zero_grad(); loss=lossf(net(xb).squeeze(1),yb); loss.backward(); opt.step()\n        net.eval()\n        with torch.no_grad():\n            va=torch.sigmoid(net(Xva_t).squeeze(1)).cpu().numpy()\n        auc=roc_auc_score(yva,va)\n        if auc>best_auc:\n            best_auc=auc; best_va=va; patience=0\n            with torch.no_grad(): best_te=torch.sigmoid(net(Xte_t).squeeze(1)).cpu().numpy()\n        else:\n            patience+=1\n            if patience>=6: break\n    return best_va, best_te","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-25T10:34:42.609994Z","iopub.execute_input":"2026-05-25T10:34:42.610653Z","iopub.status.idle":"2026-05-25T10:34:42.626840Z","shell.execute_reply.started":"2026-05-25T10:34:42.610627Z","shell.execute_reply":"2026-05-25T10:34:42.626000Z"}},"outputs":[],"execution_count":4},{"id":"afef35a3-6e73-4d0c-a75f-58f7260fdded","cell_type":"markdown","source":"## Cross-validation: train all base models per fold\nTraining = synthetic-train-fold + external. Validation/test stay synthetic. Each model writes OOF (synthetic) and averaged test predictions.","metadata":{}},{"id":"2fd15a18-d29c-4b71-89fc-7a98d77784e0","cell_type":"code","source":"y=train_fe[TARGET].values.astype(\"int8\"); nte=len(test_fe)\nkeys=[\"lgb\",\"xgb\",\"cat\",\"nn\"]\nused={\"lgb\":True,\"xgb\":HAS_XGB,\"cat\":HAS_CAT,\"nn\":(USE_NN and HAS_TORCH)}\noof ={k:np.zeros(len(train_fe)) for k in keys}\npred={k:np.zeros(nte)            for k in keys}\n\nskf=StratifiedKFold(n_splits=N_SPLITS,shuffle=True,random_state=SEED)\nfor fold,(tri,vai) in enumerate(skf.split(train_fe,y)):\n    tr_syn=train_fe.iloc[tri]\n    tr_all=pd.concat([tr_syn,ext_fe],ignore_index=True) if (USE_EXTERNAL and ext_fe is not None) else tr_syn\n    ytr=tr_all[TARGET].values.astype(\"int8\")\n    enc,glob=smoothed_te(tr_all,\"Driver\",TARGET,m=50.0)\n    def mat(frame):\n        X=frame[NUM_FEATS].copy(); X[\"Driver_te\"]=frame[\"Driver\"].map(enc).fillna(glob).values.astype(\"float32\"); return X\n    Atr=mat(tr_all).values; Ava=mat(train_fe.iloc[vai]).values; Ate=mat(test_fe).values; yva=y[vai]\n    vp,tp=fit_lgb(Atr,ytr,Ava,yva,Ate); oof[\"lgb\"][vai]=vp; pred[\"lgb\"]+=tp/N_SPLITS\n    if used[\"xgb\"]:\n        vp,tp=fit_xgb(Atr,ytr,Ava,yva,Ate); oof[\"xgb\"][vai]=vp; pred[\"xgb\"]+=tp/N_SPLITS\n    if used[\"cat\"]:\n        vp,tp=fit_cat(Atr,ytr,Ava,yva,Ate); oof[\"cat\"][vai]=vp; pred[\"cat\"]+=tp/N_SPLITS\n    if used[\"nn\"]:\n        try:\n            vp,tp=fit_nn(Atr,ytr,Ava,yva,Ate); oof[\"nn\"][vai]=vp; pred[\"nn\"]+=tp/N_SPLITS\n        except Exception as e:\n            print(\"  NN failed -> dropping from ensemble:\", repr(e)); used[\"nn\"]=False\n    msg=\" | \".join(f\"{k}={roc_auc_score(yva,oof[k][vai]):.5f}\" for k in keys if used[k])\n    print(f\"fold {fold+1}: {msg}\", flush=True)\n    del Atr,Ava,Ate,tr_all; gc.collect()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-25T10:34:42.628264Z","iopub.execute_input":"2026-05-25T10:34:42.628955Z","iopub.status.idle":"2026-05-25T11:19:19.742953Z","shell.execute_reply.started":"2026-05-25T10:34:42.628930Z","shell.execute_reply":"2026-05-25T11:19:19.742175Z"}},"outputs":[{"name":"stdout","text":"Training until validation scores don't improve for 200 rounds\nEarly stopping, best iteration is:\n[1027]\tvalid_0's auc: 0.951535\nTraining until validation sc